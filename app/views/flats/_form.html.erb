<%= simple_form_for @flat do |f| %>
  <%= f.input :name, label: "Nom" %>
  <%= f.input :description, label: "Description" %>
  <%= f.input :address, label: "Adresse" %>
  <%= f.input :price_by_night, label: "Prix par nuit (€)" %>
  <%= f.input :capacity, label: "Capacité" %>
  <%= f.association :user, label: "Hôte", label_method: :full_name, prompt: "Choisir un hôte" %>
  <%= f.input :photo, as: :file, label: "Photo" %>
  <%= f.button :submit, "Enregistrer", class: "btn btn-primary" %>
<% end %>
